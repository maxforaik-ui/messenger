```gitignore
# Dependencies
node_modules/

# Build artifacts
dist/
build/
*.js.map
*.ts.map

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs and temp files
*.log
*.tmp

# Python (if applicable)
__pycache__/
*.pyc
*.pyo
*.pyd

# Coverage
coverage/
htmlcov/
.coverage

# OS
.DS_Store
Thumbs.db

# Testing
.mypy_cache/
.pytest_cache/
.nyc_output/
coverage/

# Distribution / packaging
*.tar.gz
*.whl
*.egg
*.egg-info/

# IDE specific
*.iml
*.ipr
*.iws

# Temporary files
*~
\#*\#
*.bak
*.swp
*.swo

# Local configuration
.env.local
.env.development.local
.env.test.local
.env.production.local
```